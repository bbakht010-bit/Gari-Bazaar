rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function isSignedIn() {
      return request.auth != null;
    }

    function userDoc() {
      return firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data;
    }

    function hasDealerAccess() {
      return isSignedIn() &&
        firestore.exists(/databases/(default)/documents/users/$(request.auth.uid)) &&
        (
          userDoc().get("dealer", false) == true ||
          userDoc().role == "dealer" ||
          userDoc().role == "Dealer" ||
          userDoc().role == "DEALER" ||
          (userDoc().role is string && userDoc().role.matches('(?i)^dealer$'))
        );
    }

    function isDealerUser() {
      return hasDealerAccess();
    }

    function dealerApprovedForListingMedia() {
      return firestore.exists(/databases/(default)/documents/dealerProfiles/$(request.auth.uid)) &&
        firestore.get(/databases/(default)/documents/dealerProfiles/$(request.auth.uid)).data.get('suspended', false) == false &&
        (
          firestore.get(/databases/(default)/documents/dealerProfiles/$(request.auth.uid)).data.verificationStatus == 'verified' ||
          firestore.get(/databases/(default)/documents/dealerProfiles/$(request.auth.uid)).data.verificationStatus == 'approved'
        );
    }

    match /listings/{dealerId}/{listingId}/{fileName} {
      allow read: if true;
      allow write: if isDealerUser() &&
        request.auth.uid == dealerId &&
        dealerApprovedForListingMedia() &&
        request.resource.size < 6 * 1024 * 1024 &&
        (
          request.resource.contentType.matches('image/.*') ||
          fileName.matches('(?i).+\\.(jpg|jpeg|png|webp|gif|heic|heif)$')
        );
    }

    match /dealers/{dealerId}/profile/{fileName} {
      allow read: if true;
      allow write: if isDealerUser() &&
        request.auth.uid == dealerId &&
        request.resource.size < 6 * 1024 * 1024 &&
        (
          request.resource.contentType.matches('image/.*') ||
          fileName.matches('(?i).+\\.(jpg|jpeg|png|webp|gif|heic|heif)$')
        );
    }

    match /dealers/{dealerId}/verification/{fileName} {
      allow read: if isDealerUser() && request.auth.uid == dealerId;
      allow write: if isDealerUser() &&
        request.auth.uid == dealerId &&
        request.resource.size < 6 * 1024 * 1024 &&
        (
          request.resource.contentType.matches('application/pdf') ||
          request.resource.contentType.matches('image/.*') ||
          fileName.matches('(?i).+\\.(pdf|jpg|jpeg|png|webp)$')
        );
    }

    match /dealers/{dealerId}/gallery/{fileName} {
      allow read: if true;
      allow write: if isDealerUser() &&
        request.auth.uid == dealerId &&
        request.resource.size < 6 * 1024 * 1024 &&
        (
          request.resource.contentType.matches('image/.*') ||
          fileName.matches('(?i).+\\.(jpg|jpeg|png|webp|gif|heic|heif)$')
        );
    }

    // Buyer avatar: trust Auth UID + verified email only. Do not require Firestore `users` buyer flags
    // (dual-role / legacy docs often lacked `buyer:true`, which caused storage/unauthorized).
    match /buyers/{uid}/avatar/{fileName} {
      allow read: if true;
      allow write: if isSignedIn() &&
        request.auth.uid == uid &&
        request.auth.token.email_verified == true &&
        request.resource.size < 6 * 1024 * 1024 &&
        (
          request.resource.contentType == "image/jpeg" ||
          request.resource.contentType == "image/png" ||
          request.resource.contentType == "image/webp" ||
          fileName.matches('(?i).+\\.(jpg|jpeg|png|webp)$')
        );
    }
  }
}
