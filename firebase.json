{
  "functions": {
    "source": "functions"
  },
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "storage": {
    "rules": "storage.rules"
  },
  "hosting": {
    "public": ".",
    "cleanUrls": true,
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**",
      "node_modules/**",
      "functions/**",
      "scripts/**",
      "tests/**",
      "test-results/**",
      "playwright-report/**",
      "playwright.config.js",
      "package.json",
      "package-lock.json"
    ]
  }
}
