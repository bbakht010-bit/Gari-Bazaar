rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function isAdmin() {
      return signedIn() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
    }

    function validUserRole(role) {
      return role in ["buyer", "dealer", "admin"];
    }

    match /users/{uid} {
      // Owner can create only buyer/dealer identities. Admin role cannot be self-assigned.
      allow create: if isOwner(uid) &&
        request.resource.data.email is string &&
        validUserRole(request.resource.data.role) &&
        request.resource.data.role in ["buyer", "dealer"];
      // Owner can only update own email and timestamp; role changes are admin-only.
      allow update: if (isOwner(uid) &&
        request.resource.data.role == resource.data.role &&
        request.resource.data.email is string) || isAdmin();
      allow read, delete: if isOwner(uid) || isAdmin();
    }

    match /buyerProfiles/{uid} {
      allow create, update, delete: if isOwner(uid) || isAdmin();
      allow read: if isOwner(uid) || isAdmin();
    }

    match /dealerProfiles/{uid} {
      allow create, update, delete: if isOwner(uid) || isAdmin();
      allow read: if true;
    }

    match /listings/{listingId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }
  }
}
