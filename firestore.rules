rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function isAdmin() {
      return signedIn() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
    }

    function isDealerUser() {
      return signedIn() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "dealer";
    }

    function validUserRole(role) {
      return role in ["buyer", "dealer", "admin"];
    }

    function unchangedStatusAndSuspension() {
      return request.resource.data.get('verificationStatus', 'pending') == resource.data.get('verificationStatus', 'pending') &&
        request.resource.data.get('suspended', false) == resource.data.get('suspended', false);
    }

    function dealerPublicProfilePayloadClean() {
      return !request.resource.data.keys().hasAny(['ownerCnic', 'soldHistory']);
    }

    function dealerCarsSoldUnchanged() {
      return request.resource.data.get('carsSold', 0) == resource.data.get('carsSold', 0);
    }

    function dealerSoldHistoryNotGrowingFromClient() {
      return !resource.exists ||
        request.resource.data.get('soldHistory', []).size() <= resource.data.get('soldHistory', []).size();
    }

    function listingCoreStringsValid() {
      return request.resource.data.carName is string &&
        request.resource.data.carName.size() > 0 &&
        request.resource.data.carName.size() <= 200 &&
        request.resource.data.dealerName is string &&
        request.resource.data.dealerName.size() <= 200 &&
        request.resource.data.phone is string &&
        request.resource.data.phone.size() <= 24 &&
        request.resource.data.contactName is string &&
        request.resource.data.contactName.size() <= 120 &&
        request.resource.data.contactRole is string &&
        request.resource.data.contactRole.size() <= 120 &&
        request.resource.data.priceLakh is string &&
        request.resource.data.priceLakh.size() <= 32 &&
        request.resource.data.mileage is string &&
        request.resource.data.mileage.size() <= 96 &&
        request.resource.data.transmission is string &&
        request.resource.data.transmission.size() <= 40 &&
        request.resource.data.condition is string &&
        request.resource.data.condition.size() <= 40 &&
        request.resource.data.city is string &&
        request.resource.data.city.size() <= 80 &&
        (!('description' in request.resource.data) ||
          (request.resource.data.description is string && request.resource.data.description.size() <= 8000)) &&
        (!('bodyNote' in request.resource.data) ||
          (request.resource.data.bodyNote is string && request.resource.data.bodyNote.size() <= 2000)) &&
        request.resource.data.get('features', []).size() <= 72 &&
        request.resource.data.get('carImages', []).size() <= 28;
    }

    match /users/{uid} {
      allow create: if isOwner(uid) &&
        request.resource.data.email is string &&
        validUserRole(request.resource.data.role) &&
        request.resource.data.role in ["buyer", "dealer"];
      allow update: if (isOwner(uid) &&
        request.resource.data.role == resource.data.role &&
        request.resource.data.email is string) || isAdmin();
      allow read, delete: if isOwner(uid) || isAdmin();
    }

    match /buyerProfiles/{uid} {
      allow create, update, delete: if isOwner(uid) || isAdmin();
      allow read: if isOwner(uid) || isAdmin();
    }

    match /dealerPrivate/{uid} {
      allow read: if isOwner(uid) || isAdmin();
      allow create: if isAdmin() || (
        isOwner(uid) &&
        request.resource.data.get('soldHistory', []).size() == 0 &&
        (!('ownerCnic' in request.resource.data) ||
          (request.resource.data.ownerCnic is string && request.resource.data.ownerCnic.size() <= 24))
      );
      allow update: if isAdmin() || (
        isOwner(uid) &&
        request.resource.data.get('soldHistory', []).size() <= 600 &&
        dealerSoldHistoryNotGrowingFromClient() &&
        (!('ownerCnic' in request.resource.data) ||
          (request.resource.data.ownerCnic is string && request.resource.data.ownerCnic.size() <= 24))
      );
      allow delete: if isAdmin();
    }

    match /dealerProfiles/{uid} {
      allow read: if true;
      allow create: if isAdmin() || (
        isOwner(uid) &&
        isDealerUser() &&
        request.resource.data.verificationStatus == 'pending' &&
        request.resource.data.get('suspended', false) == false &&
        (!('carsSold' in request.resource.data) || request.resource.data.carsSold == 0) &&
        dealerPublicProfilePayloadClean()
      );
      allow update: if isAdmin() || (
        isOwner(uid) &&
        isDealerUser() &&
        unchangedStatusAndSuspension() &&
        dealerPublicProfilePayloadClean() &&
        dealerCarsSoldUnchanged()
      );
      allow delete: if isAdmin();
    }

    match /listings/{listingId} {
      allow read: if true;
      allow create: if isAdmin() ||
        (isDealerUser() &&
          request.resource.data.dealerId == request.auth.uid &&
          request.resource.data.moderationStatus == 'live' &&
          listingCoreStringsValid());
      allow update: if isAdmin() ||
        (isDealerUser() &&
          resource.data.dealerId == request.auth.uid &&
          request.resource.data.dealerId == resource.data.dealerId &&
          resource.data.moderationStatus != 'removed' &&
          request.resource.data.moderationStatus == 'live' &&
          listingCoreStringsValid());
      allow delete: if isAdmin() ||
        (isDealerUser() && resource.data.dealerId == request.auth.uid);
    }

    match /dealerChangeRequests/{requestId} {
      allow create: if isDealerUser() &&
        request.resource.data.dealerId == request.auth.uid &&
        request.resource.data.status == "pending" &&
        (!('changes' in request.resource.data) || (
          !request.resource.data.changes.keys().hasAny(['verificationStatus', 'suspended', 'carsSold', 'soldHistory'])
        ));
      allow read: if isAdmin() ||
        (isDealerUser() && resource.data.dealerId == request.auth.uid);
      allow update, delete: if isAdmin();
    }
  }
}
