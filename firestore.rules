rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    // Admin: trusted Firebase Auth custom claim (synced from Firestore by Cloud Function), OR Firestore role until claims propagate.
    function isAdmin() {
      return signedIn() && (
        request.auth.token.admin == true ||
        (
          exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin"
        )
      );
    }

    function ownerEscalatesToAdmin() {
      return request.resource.data.get('role', '') == 'admin' &&
        resource.data.get('role', '') != 'admin';
    }

    function userData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function hasDealerAccess() {
      return signedIn() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        (userData().role == "dealer" || userData().get("dealer", false) == true);
    }

    function isDealerUser() {
      return signedIn() && hasDealerAccess();
    }

    function validUserRole(role) {
      return role in ["buyer", "dealer", "admin"];
    }

    function unchangedStatusAndSuspension() {
      return request.resource.data.get('verificationStatus', 'pending') == resource.data.get('verificationStatus', 'pending') &&
        request.resource.data.get('suspended', false) == resource.data.get('suspended', false);
    }

    function dealerPublicProfilePayloadClean() {
      return !request.resource.data.keys().hasAny([
        'ownerCnic',
        'soldHistory',
        'registrationDocumentUrl',
        'verificationDocument',
        'employees',
        'plan',
        'planPreference',
        'paymentStatus'
      ]);
    }

    function dealerCarsSoldProgressValid() {
      let oldValue = resource.data.get('carsSold', 0);
      let newValue = request.resource.data.get('carsSold', 0);
      return newValue == oldValue;
    }

    function planPreferenceValid(docData) {
      return !('planPreference' in docData) ||
        docData.planPreference in ['free', 'growth', 'pro', 'professional'];
    }

    function verificationDocumentValid(docData) {
      return !('verificationDocument' in docData) || (
        docData.verificationDocument is map &&
        docData.verificationDocument.get('storagePath', '') is string &&
        docData.verificationDocument.get('storagePath', '').size() <= 500 &&
        docData.verificationDocument.get('fileName', '') is string &&
        docData.verificationDocument.get('fileName', '').size() <= 200 &&
        docData.verificationDocument.get('contentType', '') is string &&
        docData.verificationDocument.get('contentType', '').size() <= 120 &&
        docData.verificationDocument.get('uploadedAt', '') is string &&
        docData.verificationDocument.get('uploadedAt', '').size() <= 80 &&
        docData.verificationDocument.get('legacyDownloadUrl', '') is string &&
        docData.verificationDocument.get('legacyDownloadUrl', '').size() <= 2000
      );
    }

    function dealerPrivateOwnerCreateValid() {
      return request.resource.data.get('soldHistory', []).size() == 0 &&
        request.resource.data.get('employees', []).size() == 0 &&
        request.resource.data.get('plan', 'free') == 'free' &&
        request.resource.data.get('paymentStatus', '') == '' &&
        (!('ownerCnic' in request.resource.data) ||
          (request.resource.data.ownerCnic is string && request.resource.data.ownerCnic.size() <= 24)) &&
        planPreferenceValid(request.resource.data) &&
        verificationDocumentValid(request.resource.data);
    }

    function dealerPrivateOwnerUpdateValid() {
      return request.resource.data.get('soldHistory', []) == resource.data.get('soldHistory', []) &&
        request.resource.data.get('employees', []) == resource.data.get('employees', []) &&
        request.resource.data.get('plan', 'free') == resource.data.get('plan', 'free') &&
        request.resource.data.get('paymentStatus', '') == resource.data.get('paymentStatus', '') &&
        (!('ownerCnic' in request.resource.data) ||
          (request.resource.data.ownerCnic is string && request.resource.data.ownerCnic.size() <= 24)) &&
        planPreferenceValid(request.resource.data) &&
        verificationDocumentValid(request.resource.data);
    }

    match /users/{uid} {
      allow create: if isOwner(uid) &&
        request.resource.data.email is string &&
        validUserRole(request.resource.data.role) &&
        request.resource.data.role in ["buyer", "dealer"];
      allow update: if isAdmin() ||
        (isOwner(uid) &&
          request.resource.data.role == resource.data.role &&
          request.resource.data.email is string &&
          !ownerEscalatesToAdmin());
      allow read, delete: if isOwner(uid) || isAdmin();
    }

    match /buyerProfiles/{uid} {
      allow create, update, delete: if isOwner(uid) || isAdmin();
      allow read: if isOwner(uid) || isAdmin();
    }

    match /dealerPrivate/{uid} {
      allow read: if isOwner(uid) || isAdmin();
      allow create: if isAdmin() || (
        isOwner(uid) &&
        dealerPrivateOwnerCreateValid()
      );
      allow update: if isAdmin() || (
        isOwner(uid) &&
        dealerPrivateOwnerUpdateValid()
      );
      allow delete: if isAdmin();
    }

    match /dealerProfiles/{uid} {
      allow read: if true;
      allow create: if isAdmin() || (
        isOwner(uid) &&
        isDealerUser() &&
        request.resource.data.verificationStatus == 'pending' &&
        request.resource.data.get('suspended', false) == false &&
        (!('carsSold' in request.resource.data) || request.resource.data.carsSold == 0) &&
        dealerPublicProfilePayloadClean()
      );
      allow update: if isAdmin() || (
        isOwner(uid) &&
        isDealerUser() &&
        unchangedStatusAndSuspension() &&
        dealerPublicProfilePayloadClean() &&
        dealerCarsSoldProgressValid()
      );
      allow delete: if isAdmin();
    }

    match /listings/{listingId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /dealerChangeRequests/{requestId} {
      allow create: if isDealerUser() &&
        request.resource.data.dealerId == request.auth.uid &&
        request.resource.data.status == "pending" &&
        (!('changes' in request.resource.data) || (
          !request.resource.data.changes.keys().hasAny([
            'verificationStatus',
            'suspended',
            'carsSold',
            'soldHistory',
            'registrationDocumentUrl',
            'verificationDocument',
            'employees',
            'plan',
            'planPreference',
            'paymentStatus'
          ])
        )) &&
        (!('privateChanges' in request.resource.data) || (
          request.resource.data.privateChanges is map &&
          request.resource.data.privateChanges.keys().hasOnly(['verificationDocument']) &&
          verificationDocumentValid(request.resource.data.privateChanges)
        ));
      allow read: if isAdmin() ||
        (isDealerUser() && resource.data.dealerId == request.auth.uid);
      allow update, delete: if isAdmin();
    }
  }
}
